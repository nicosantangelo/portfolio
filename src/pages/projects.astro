---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Centered from '../components/Centered.astro';

const posts = await getCollection('blog');
posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const lastPost = posts[0];
---

<BaseLayout title="projects | nicosantangelo" description="Projects that I've worked on">
  <Centered>
    <div>
      <h5 class="title">Things I've wrote</h5>
      <ul class="list">
        <li>
          <a href="https://broken.nicosantangelo.com">
            Broken software exhibition
          </a>
        </li>
        </li>
        <li>
          <a href="https://github.com/nicosantangelo?tab=repositories&q=extension&type=&language=&sort=">
            Chrome extensions
          </a>
        </li>
        <li>
          <a href="https://packagecontrol.io/browse/authors/nicosantangelo">
            Sublime text packages
          </a>
        </li>
        <li>
          <a href="http://langyapp.github.io/">Other projects</a>
        </li>
        <li>
          <a href={`/blog/${lastPost.slug}`}>Last blog post</a>
        </li>
      </ul>
    </div>
  </Centered>
</BaseLayout>

<style>
  .title {
    font-weight: 500;
    margin-bottom: 1rem;
  }

  .list {
    padding: 0 16px;
  }

  .list li {
    margin: 20px 0;
  }

  .list li::marker {
    color: var(--h5-color);
  }
</style>
